{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft": "Warning", "Microsoft.EntityFrameworkCore": "Warning", "System": "Warning" }
    },
    "WriteTo": [
      { "Name": "Console", "Args": { "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}" } },
      { "Name": "File", "Args": { "path": "Logs/log-.txt", "rollingInterval": "Day", "retainedFileCountLimit": 30 } },
      { "Name": "Seq", "Args": { "serverUrl": "http://seq:5341" } }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=orderdb;User Id=sa;Password=Strong@Passw0rd!;TrustServerCertificate=True;",
    "Redis": "localhost:6379"
  },
  "ServiceUrls": {
    "CatalogService": "http://localhost:5002/",
    "UserAuthService": "http://localhost:5001/"
  },
  "RabbitMQ": {
    "Host": "localhost"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForJWTTokenGeneration123456789",
    "Issuer": "StoreApi",
    "Audience": "StoreApiClients",
    "ExpiryMinutes": 60
  }
}
