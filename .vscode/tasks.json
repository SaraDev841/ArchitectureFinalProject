{
  "version": "2.0.0",
  "tasks": [
    // ── Individual service tasks ───────────────────────────────────────────

    {
      "label": "Run: ApiGateway",
      "type": "shell",
      "command": "dotnet run",
      "options": {
        "cwd": "${workspaceFolder}/ApiGateway",
        "env": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "ASPNETCORE_URLS": "http://localhost:5000"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "dotnet",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting ApiGateway",
          "endsPattern": "Now listening on"
        }
      },
      "presentation": {
        "label": "ApiGateway",
        "group": "build",
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "close": false
      }
    },

