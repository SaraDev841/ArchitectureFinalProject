    // ── Compound tasks ─────────────────────────────────────────────────────

    {
      "label": "Run All Services",
      "dependsOn": [
        "Run: ApiGateway",
        "Run: UserAuthService",
        "Run: ProductCatalogService",
        "Run: OrderService",
        "Run: InventoryService",
        "Run: NotificationService",
        "Run: BffService",
        "Run: Frontend"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    {
      "label": "Run All Services + Infrastructure",
      "dependsOn": [
        "Start: Infrastructure (Docker)",
        "Run: ApiGateway",
        "Run: UserAuthService",
        "Run: ProductCatalogService",
        "Run: OrderService",
        "Run: InventoryService",
        "Run: NotificationService",
        "Run: BffService",
        "Run: Frontend"
      ],
      "dependsOrder": "parallel",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
