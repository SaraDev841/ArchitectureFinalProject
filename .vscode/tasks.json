    // ── Infrastructure shortcut ────────────────────────────────────────────

    {
      "label": "Start: Infrastructure (Docker)",
      "type": "shell",
      "command": "docker compose up sqlserver redis rabbitmq seq",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "docker",
        "pattern": { "regexp": "^$" },
